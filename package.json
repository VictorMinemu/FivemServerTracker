{
  "name": "fivemservertracker",
  "version": "1.0.0",
  "type": "module",
  "description": "FiveM server tracker with protobuf stream decoding and historical analytics",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:web": "astro dev",
    "test": "vitest run --reporter=verbose",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "typecheck": "tsc --noEmit",
    "proto:js": "npx pbjs -t static-module -w es6 -o src/proto/generated/master.js src/proto/master.proto",
    "proto:ts": "npx pbts -o src/proto/generated/master.d.ts src/proto/generated/master.js",
    "proto:gen": "npm run proto:js && npm run proto:ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VictorMinemu/FivemServerTracker.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/VictorMinemu/FivemServerTracker/issues"
  },
  "homepage": "https://github.com/VictorMinemu/FivemServerTracker#readme",
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/node": "^9.5.4",
    "@astrojs/preact": "^4.1.3",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^5.18.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "node-cron": "^4.2.1",
    "preact": "^10.28.4",
    "protobufjs": "^7.5.4",
    "tailwindcss": "^4.2.1",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.31.9",
    "protobufjs-cli": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
