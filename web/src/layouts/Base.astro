---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import CategoryNav from '../components/CategoryNav.astro';
import { getCategories } from '../lib/queries.js';

interface Props {
  title: string;
}

const { title } = Astro.props;
const categories = getCategories();
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Browse and monitor FiveM servers with real-time player counts and historical trends" />
    <title>{title} | FiveM Server Tracker</title>
    <ViewTransitions />
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 dark:bg-gray-950 dark:text-gray-100">
    <header class="border-b border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-900">
      <div class="mx-auto max-w-7xl px-4">
        <nav class="flex items-center py-3">
          <a href="/" class="text-lg font-semibold tracking-tight hover:opacity-80">
            FiveM Server Tracker
          </a>
        </nav>
        <div class="pb-3">
          <CategoryNav categories={categories} />
        </div>
      </div>
    </header>
    <main class="mx-auto max-w-7xl px-4 py-6">
      <slot />
    </main>
  </body>
</html>
