---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import CategoryNav from '../components/CategoryNav.astro';
import { getCategories } from '../lib/queries.js';

interface Props {
  title: string;
}

const { title } = Astro.props;
const categories = getCategories();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Browse and monitor FiveM servers with real-time player counts and historical trends" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title} | FiveM Tracker</title>
    <ViewTransitions />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Ambient background glow -->
    <div class="ambient-glow" aria-hidden="true"></div>

    <!-- Header -->
    <header class="sticky top-0 z-50 border-b border-edge bg-surface-1/80 backdrop-blur-xl">
      <div class="mx-auto max-w-[1480px] px-5">
        <div class="flex items-center justify-between h-14">
          <a href="/" class="flex items-center gap-2.5 group">
            <div class="h-8 w-8 rounded-lg bg-accent/10 flex items-center justify-center transition-colors group-hover:bg-accent/20">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="text-accent">
                <rect x="2" y="2" width="5" height="5" rx="1" fill="currentColor" opacity="0.9"/>
                <rect x="9" y="2" width="5" height="5" rx="1" fill="currentColor" opacity="0.5"/>
                <rect x="2" y="9" width="5" height="5" rx="1" fill="currentColor" opacity="0.5"/>
                <rect x="9" y="9" width="5" height="5" rx="1" fill="currentColor" opacity="0.3"/>
              </svg>
            </div>
            <span class="text-lg font-bold tracking-tight">
              <span class="text-txt">FiveM</span><span class="text-accent">Tracker</span>
            </span>
          </a>
        </div>
        <CategoryNav categories={categories} />
      </div>
    </header>

    <!-- Main -->
    <main class="relative flex-1 mx-auto w-full max-w-[1480px] px-5 py-8">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="relative border-t border-edge">
      <div class="mx-auto max-w-[1480px] px-5 py-6 text-center text-sm text-txt-3">
        FiveM Server Tracker &mdash; Real-time server monitoring
      </div>
    </footer>
  </body>
</html>
