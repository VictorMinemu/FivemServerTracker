---
interface Props {
  categories: { slug: string; label: string }[];
  activeCategory?: string;
}

const { categories, activeCategory } = Astro.props;
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '';
---

<nav class="flex gap-2 overflow-x-auto pb-3 -mb-px scrollbar-none" aria-label="Server categories">
  <a
    href="/"
    class:list={[
      'shrink-0 rounded-lg px-4 py-1.5 text-sm font-medium transition-all duration-200',
      !activeCategory && isHome
        ? 'bg-accent text-surface-0 shadow-[0_2px_12px_-2px] shadow-accent/30'
        : 'text-txt-2 hover:text-txt hover:bg-surface-3',
    ]}
  >
    All
  </a>
  {categories.map((cat) => (
    <a
      href={`/category/${cat.slug}`}
      class:list={[
        'shrink-0 rounded-lg px-4 py-1.5 text-sm font-medium transition-all duration-200',
        activeCategory === cat.slug
          ? 'bg-accent text-surface-0 shadow-[0_2px_12px_-2px] shadow-accent/30'
          : 'text-txt-2 hover:text-txt hover:bg-surface-3',
      ]}
    >
      {cat.label}
    </a>
  ))}
</nav>
