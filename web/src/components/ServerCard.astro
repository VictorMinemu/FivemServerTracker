---
/**
 * ServerCard Component
 *
 * Renders an individual server as a clickable card showing its name, player count,
 * online status, gamemode, map, and icon. The entire card links to the server detail page.
 *
 * @param id - FiveM endpoint ID
 * @param name - Clean server hostname
 * @param players - Current player count
 * @param maxPlayers - Maximum player slots
 * @param isOnline - Whether the server is currently online
 * @param gamemode - Server gamemode/gametype (nullable)
 * @param mapname - Current map name (nullable)
 * @param iconUrl - URL for the server icon image
 * @param lastSeenAt - When the server was last detected in a poll
 * @param updatedAt - When the server record was last updated in the database
 */

import { getConnectUrl } from '../lib/url-helpers.js';
import { localeToFlag } from '../lib/locale-helpers.js';

interface Props {
  id: string;
  name: string;
  players: number;
  maxPlayers: number;
  isOnline: boolean;
  gamemode: string | null;
  mapname: string | null;
  locale: string | null;
  iconUrl: string;
  lastSeenAt: Date;
  updatedAt: Date;
}

const { id, name, players, maxPlayers, isOnline, gamemode, mapname, locale, iconUrl, lastSeenAt, updatedAt } = Astro.props;
const flag = localeToFlag(locale);

/**
 * Formats a Date as a relative time string (e.g., "5 min ago", "2 hours ago").
 * Falls back to ISO date for timestamps older than 7 days.
 */
function formatRelativeTime(date: Date): string {
  const now = Date.now();
  const diffMs = now - date.getTime();
  const diffSec = Math.floor(diffMs / 1000);
  const diffMin = Math.floor(diffSec / 60);
  const diffHr = Math.floor(diffMin / 60);
  const diffDay = Math.floor(diffHr / 24);

  if (diffSec < 60) return 'just now';
  if (diffMin < 60) return `${diffMin} min ago`;
  if (diffHr < 24) return `${diffHr}h ago`;
  if (diffDay < 7) return `${diffDay}d ago`;
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

const relativeTime = formatRelativeTime(updatedAt);
const playerPercent = maxPlayers > 0 ? Math.round((players / maxPlayers) * 100) : 0;
---

<a
  href={`/server/${id}`}
  class="group block rounded-lg border border-gray-200 bg-white p-4 shadow-sm transition-shadow hover:shadow-md dark:border-gray-700 dark:bg-gray-800"
>
  <div class="flex items-start gap-3">
    <img
      src={iconUrl}
      alt={`${name} icon`}
      width="48"
      height="48"
      loading="lazy"
      class="h-12 w-12 shrink-0 rounded-lg object-cover"
    />
    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-2">
        <span
          class:list={[
            'inline-block h-2.5 w-2.5 shrink-0 rounded-full',
            isOnline ? 'bg-green-500' : 'bg-red-500',
          ]}
          title={isOnline ? 'Online' : 'Offline'}
        ></span>
        {flag && (
          <span class="shrink-0 text-base" title={locale ?? ''} aria-label={`Server locale: ${locale}`}>{flag}</span>
        )}
        <h3 class="truncate text-sm font-semibold text-gray-900 group-hover:text-blue-600 dark:text-gray-100 dark:group-hover:text-blue-400">
          {name}
        </h3>
      </div>
      <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
        <span class="font-medium text-gray-900 dark:text-gray-200">{players}</span>/{maxPlayers} players
      </p>
    </div>
  </div>

  <div class="mt-3 flex flex-wrap items-center gap-2">
    {gamemode && (
      <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800 dark:bg-blue-900/40 dark:text-blue-300">
        {gamemode}
      </span>
    )}
    {mapname && (
      <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-700 dark:bg-gray-700 dark:text-gray-300">
        {mapname}
      </span>
    )}
  </div>

  <p class="mt-2 text-xs text-gray-400 dark:text-gray-500">
    Last updated {relativeTime}
  </p>
</a>
