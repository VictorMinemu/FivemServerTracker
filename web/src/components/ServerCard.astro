---
import { localeToFlag } from '../lib/locale-helpers.js';

interface Props {
  id: string;
  name: string;
  players: number;
  maxPlayers: number;
  isOnline: boolean;
  gamemode: string | null;
  mapname: string | null;
  locale: string | null;
  iconUrl: string;
  lastSeenAt: Date;
  updatedAt: Date;
}

const { id, name, players, maxPlayers, isOnline, gamemode, mapname, locale, iconUrl, lastSeenAt, updatedAt } = Astro.props;
const flag = localeToFlag(locale);

function formatRelativeTime(date: Date): string {
  const now = Date.now();
  const diffMs = now - date.getTime();
  const diffSec = Math.floor(diffMs / 1000);
  const diffMin = Math.floor(diffSec / 60);
  const diffHr = Math.floor(diffMin / 60);
  const diffDay = Math.floor(diffHr / 24);

  if (diffSec < 60) return 'just now';
  if (diffMin < 60) return `${diffMin}m ago`;
  if (diffHr < 24) return `${diffHr}h ago`;
  if (diffDay < 7) return `${diffDay}d ago`;
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

const relativeTime = formatRelativeTime(updatedAt);
const playerPercent = maxPlayers > 0 ? Math.round((players / maxPlayers) * 100) : 0;

const barColor = playerPercent > 85
  ? 'bg-offline'
  : playerPercent > 60
    ? 'bg-warn'
    : 'bg-accent';
---

<a
  href={`/server/${id}`}
  class="card-animate group block rounded-xl border border-edge bg-surface-2 p-5 transition-all duration-300 hover:border-accent/30 hover:bg-surface-3 hover:shadow-[0_4px_40px_-8px] hover:shadow-accent/8 hover:-translate-y-0.5"
>
  <!-- Top row: icon + info -->
  <div class="flex items-start gap-3.5">
    <img
      src={iconUrl}
      alt=""
      width="44"
      height="44"
      loading="lazy"
      class="h-11 w-11 shrink-0 rounded-lg object-cover ring-1 ring-edge"
    />
    <div class="min-w-0 flex-1">
      <!-- Name + status -->
      <div class="flex items-center gap-2">
        <span
          class:list={[
            'inline-block h-2 w-2 shrink-0 rounded-full',
            isOnline ? 'bg-online dot-online shadow-[0_0_6px] shadow-online/60' : 'bg-offline',
          ]}
          title={isOnline ? 'Online' : 'Offline'}
        ></span>
        {flag && (
          <span class="shrink-0 text-sm" title={locale ?? ''}>{flag}</span>
        )}
        <h3 class="truncate text-[15px] font-semibold text-txt transition-colors group-hover:text-accent">
          {name}
        </h3>
      </div>

      <!-- Player count + capacity bar -->
      <div class="mt-2.5 flex items-center gap-3">
        <span class="text-sm text-txt-2 tabular-nums">
          <span class="font-semibold text-txt">{players}</span>
          <span class="text-txt-3">/{maxPlayers}</span>
        </span>
        <div class="flex-1 h-1.5 rounded-full bg-edge overflow-hidden">
          <div
            class:list={['h-full rounded-full transition-all duration-500', barColor]}
            style={`width: ${playerPercent}%`}
          />
        </div>
        <span class="text-[11px] font-medium text-txt-3 tabular-nums">{playerPercent}%</span>
      </div>
    </div>
  </div>

  <!-- Badges -->
  <div class="mt-3.5 flex flex-wrap items-center gap-1.5">
    {gamemode && (
      <span class="rounded-md bg-accent/10 px-2.5 py-0.5 text-[11px] font-semibold text-accent">
        {gamemode}
      </span>
    )}
    {mapname && (
      <span class="rounded-md bg-surface-hover px-2.5 py-0.5 text-[11px] font-medium text-txt-2">
        {mapname}
      </span>
    )}
  </div>

  <!-- Footer -->
  <div class="mt-3 text-[11px] font-medium text-txt-3">
    {relativeTime}
  </div>
</a>
