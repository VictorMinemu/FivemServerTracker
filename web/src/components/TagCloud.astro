---
interface Props {
  tags: { tag: string; count: number }[];
}

const { tags } = Astro.props;
---

{tags.length > 0 && (
  <div class="flex flex-wrap gap-2">
    {tags.map(({ tag, count }) => (
      <a
        href={`/?tag=${encodeURIComponent(tag)}`}
        class="rounded-lg bg-surface-2 px-3 py-1 text-xs font-medium text-txt-2 ring-1 ring-edge transition-all duration-200 hover:ring-accent/30 hover:text-txt hover:bg-surface-3"
      >
        {tag}
        <span class="ml-1 text-txt-3">{count}</span>
      </a>
    ))}
  </div>
)}
