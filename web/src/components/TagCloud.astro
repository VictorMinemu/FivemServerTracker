---
/**
 * Tag Cloud Component
 *
 * Renders a flex-wrap container of tag pills showing popular tags
 * with their occurrence counts. Each tag links to the listing page
 * filtered by that tag.
 *
 * @example
 * ```astro
 * <TagCloud tags={[{ tag: 'roleplay', count: 45 }, { tag: 'economy', count: 32 }]} />
 * ```
 */

interface Props {
  /** Array of tags with occurrence counts */
  tags: { tag: string; count: number }[];
}

const { tags } = Astro.props;
---

{tags.length > 0 && (
  <div class="flex flex-wrap gap-2">
    {tags.map(({ tag, count }) => (
      <a
        href={`/?tag=${encodeURIComponent(tag)}`}
        class="rounded-full bg-gray-100 px-3 py-1 text-xs text-gray-600 transition-colors hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-gray-700"
      >
        {tag} <span class="text-gray-400 dark:text-gray-500">({count})</span>
      </a>
    ))}
  </div>
)}
