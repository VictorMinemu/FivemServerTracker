---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
  searchParams: URLSearchParams;
}

const { currentPage, totalPages, baseUrl, searchParams } = Astro.props;

function getPageUrl(page: number): string {
  const params = new URLSearchParams(searchParams.toString());
  if (page <= 1) {
    params.delete('page');
  } else {
    params.set('page', String(page));
  }
  const qs = params.toString();
  return qs ? `${baseUrl}?${qs}` : baseUrl;
}

const WINDOW_SIZE = 5;
const halfWindow = Math.floor(WINDOW_SIZE / 2);
let windowStart = Math.max(1, currentPage - halfWindow);
let windowEnd = Math.min(totalPages, windowStart + WINDOW_SIZE - 1);
if (windowEnd - windowStart + 1 < WINDOW_SIZE) {
  windowStart = Math.max(1, windowEnd - WINDOW_SIZE + 1);
}

const pages: number[] = [];
for (let i = windowStart; i <= windowEnd; i++) {
  pages.push(i);
}

const hasPrev = currentPage > 1;
const hasNext = currentPage < totalPages;
const showFirst = windowStart > 1;
const showLast = windowEnd < totalPages;

const btnBase = 'inline-flex items-center justify-center rounded-lg px-3 py-2 text-sm font-medium transition-all duration-200 min-w-[40px]';
const btnActive = 'bg-accent text-surface-0 shadow-[0_2px_12px_-2px] shadow-accent/30';
const btnDefault = 'text-txt-2 bg-surface-2 ring-1 ring-edge hover:bg-surface-3 hover:text-txt';
const btnDisabled = 'pointer-events-none text-txt-3 bg-surface-2/50 ring-1 ring-edge/50';
---

{totalPages > 1 && (
  <nav aria-label="Pagination" class="mt-10 flex items-center justify-center gap-1.5 fade-in">
    {showFirst && (
      <a href={getPageUrl(1)} class:list={[btnBase, btnDefault]} aria-label="First page">
        &laquo;
      </a>
    )}

    {hasPrev ? (
      <a href={getPageUrl(currentPage - 1)} class:list={[btnBase, btnDefault]} aria-label="Previous page">
        &lsaquo;
      </a>
    ) : (
      <span class:list={[btnBase, btnDisabled]} aria-disabled="true">&lsaquo;</span>
    )}

    {windowStart > 2 && (
      <span class="px-1 text-sm text-txt-3">&hellip;</span>
    )}

    {pages.map((page) =>
      page === currentPage ? (
        <span class:list={[btnBase, btnActive]} aria-current="page">
          {page}
        </span>
      ) : (
        <a href={getPageUrl(page)} class:list={[btnBase, btnDefault]}>
          {page}
        </a>
      )
    )}

    {windowEnd < totalPages - 1 && (
      <span class="px-1 text-sm text-txt-3">&hellip;</span>
    )}

    {hasNext ? (
      <a href={getPageUrl(currentPage + 1)} class:list={[btnBase, btnDefault]} aria-label="Next page">
        &rsaquo;
      </a>
    ) : (
      <span class:list={[btnBase, btnDisabled]} aria-disabled="true">&rsaquo;</span>
    )}

    {showLast && (
      <a href={getPageUrl(totalPages)} class:list={[btnBase, btnDefault]} aria-label="Last page">
        &raquo;
      </a>
    )}
  </nav>
)}
