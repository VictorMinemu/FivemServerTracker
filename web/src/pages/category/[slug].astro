---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import ServerCard from '../../components/ServerCard.astro';
import ServerGrid from '../../components/ServerGrid.astro';
import CategoryNav from '../../components/CategoryNav.astro';
import { db } from '../../lib/db.js';
import { getServerListing, getCategories, CATEGORY_MAP } from '../../lib/queries.js';
import { getServerIconUrl } from '../../lib/url-helpers.js';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/');
}

const catDef = CATEGORY_MAP[slug];
if (!catDef) {
  return Astro.redirect('/');
}

const categories = getCategories();
const categoryLabel = catDef.label;

const url = Astro.url;
const page = Math.max(1, Number(url.searchParams.get('page')) || 1);
const sort = (url.searchParams.get('sort') === 'name' ? 'name' : 'players') as 'players' | 'name';
const sortDir = (url.searchParams.get('sortDir') === 'asc' ? 'asc' : 'desc') as 'asc' | 'desc';

const result = await getServerListing(db, { category: slug, page, sort, sortDir });

function pageUrl(p: number): string {
  const params = new URLSearchParams(url.searchParams);
  params.set('page', String(p));
  return `/category/${slug}?${params.toString()}`;
}
---

<Base title={`${categoryLabel} Servers`}>
  <div class="mb-6">
    <CategoryNav categories={categories} activeCategory={slug} />
  </div>

  <!-- Page header -->
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between mb-6">
    <h1 class="text-2xl font-bold tracking-tight">
      {categoryLabel} Servers
      <span class="ml-2 text-base font-medium text-txt-3">
        ({result.total.toLocaleString()})
      </span>
    </h1>

    <!-- Sort controls -->
    <div class="flex items-center gap-2">
      <span class="text-xs font-semibold uppercase tracking-widest text-txt-3">Sort</span>
      <div class="flex gap-1 rounded-lg bg-surface-0 p-1 ring-1 ring-edge">
        <a
          href={`/category/${slug}?sort=players&sortDir=desc`}
          class:list={[
            'rounded-md px-3 py-1.5 text-xs font-semibold transition-all duration-200',
            sort === 'players'
              ? 'bg-accent text-surface-0'
              : 'text-txt-2 hover:text-txt hover:bg-surface-3',
          ]}
        >
          Most Players
        </a>
        <a
          href={`/category/${slug}?sort=name&sortDir=asc`}
          class:list={[
            'rounded-md px-3 py-1.5 text-xs font-semibold transition-all duration-200',
            sort === 'name'
              ? 'bg-accent text-surface-0'
              : 'text-txt-2 hover:text-txt hover:bg-surface-3',
          ]}
        >
          Name A–Z
        </a>
      </div>
    </div>
  </div>

  <!-- Server grid -->
  {result.servers.length > 0 ? (
    <ServerGrid>
      {result.servers.map((server) => (
        <ServerCard
          id={server.id}
          name={server.hostnameClean}
          players={server.currentPlayers}
          maxPlayers={server.maxPlayers}
          isOnline={server.isOnline}
          gamemode={server.gametype}
          mapname={server.mapname}
          locale={server.locale}
          iconUrl={getServerIconUrl(server.id, server.iconVersion)}
          lastSeenAt={server.lastSeenAt}
          updatedAt={server.updatedAt}
        />
      ))}
    </ServerGrid>
  ) : (
    <div class="flex flex-col items-center justify-center rounded-xl border border-edge bg-surface-2 py-20 text-center">
      <p class="text-lg font-semibold text-txt-2">No servers found</p>
      <p class="mt-1 text-sm text-txt-3">No servers in this category yet</p>
    </div>
  )}

  <!-- Pagination -->
  {result.totalPages > 1 && (
    <nav class="mt-10 flex items-center justify-center gap-2 fade-in" aria-label="Pagination">
      {page > 1 && (
        <a
          href={pageUrl(page - 1)}
          class="rounded-lg bg-surface-2 px-4 py-2 text-sm font-medium text-txt-2 ring-1 ring-edge transition-all hover:bg-surface-3 hover:text-txt"
        >
          Previous
        </a>
      )}
      <span class="px-3 py-2 text-sm font-medium text-txt-3 tabular-nums">
        Page {page} of {result.totalPages}
      </span>
      {page < result.totalPages && (
        <a
          href={pageUrl(page + 1)}
          class="rounded-lg bg-surface-2 px-4 py-2 text-sm font-medium text-txt-2 ring-1 ring-edge transition-all hover:bg-surface-3 hover:text-txt"
        >
          Next
        </a>
      )}
    </nav>
  )}
</Base>
