---
export const prerender = false;

import Base from '../layouts/Base.astro';
import ServerCard from '../components/ServerCard.astro';
import ServerGrid from '../components/ServerGrid.astro';
import Pagination from '../components/Pagination.astro';
import SearchFilters from '../components/SearchFilters.tsx';
import TagCloud from '../components/TagCloud.astro';
import { db } from '../lib/db.js';
import { getServerListing, getCategories, getPopularTags, getPopularLocales } from '../lib/queries.js';
import { getServerIconUrl } from '../lib/url-helpers.js';
import { localeToFlag, localeToRegionName } from '../lib/locale-helpers.js';

const url = new URL(Astro.request.url);
const searchParams = url.searchParams;

const q = searchParams.get('q') ?? undefined;
const category = searchParams.get('category') ?? undefined;
const gamemode = searchParams.get('gamemode') ?? undefined;
const tag = searchParams.get('tag') ?? undefined;
const locale = searchParams.get('locale') ?? undefined;
const sort = (searchParams.get('sort') as 'players' | 'name' | undefined) ?? undefined;
const sortDir = (searchParams.get('sortDir') as 'asc' | 'desc' | undefined) ?? undefined;

const rawPage = searchParams.get('page');
const page = rawPage ? Math.max(1, parseInt(rawPage, 10) || 1) : 1;

const rawMinPlayers = searchParams.get('minPlayers');
const minPlayers = rawMinPlayers ? parseInt(rawMinPlayers, 10) : undefined;

const rawMaxPlayers = searchParams.get('maxPlayers');
const maxPlayers = rawMaxPlayers ? parseInt(rawMaxPlayers, 10) : undefined;

const listing = await getServerListing(db, {
  q,
  gamemode,
  category,
  tag,
  locale,
  minPlayers: Number.isNaN(minPlayers) ? undefined : minPlayers,
  maxPlayers: Number.isNaN(maxPlayers) ? undefined : maxPlayers,
  sort,
  sortDir,
  page,
});

const categories = getCategories();
const popularTags = await getPopularTags(db, 20);
const popularLocales = await getPopularLocales(db);
const localeOptions = popularLocales.map((l) => ({
  locale: l.locale,
  flag: localeToFlag(l.locale),
  label: localeToRegionName(l.locale),
  count: l.count,
}));

interface ActiveFilter {
  label: string;
  paramKey: string;
}

const activeFilters: ActiveFilter[] = [];
if (q) activeFilters.push({ label: `Search: ${q}`, paramKey: 'q' });
if (category) {
  const cat = categories.find((c) => c.slug === category);
  activeFilters.push({ label: `Category: ${cat?.label ?? category}`, paramKey: 'category' });
}
if (gamemode) activeFilters.push({ label: `Gamemode: ${gamemode}`, paramKey: 'gamemode' });
if (locale) activeFilters.push({ label: `${localeToFlag(locale)} ${localeToRegionName(locale)}`, paramKey: 'locale' });
if (minPlayers !== undefined && !Number.isNaN(minPlayers)) activeFilters.push({ label: `Min: ${minPlayers}`, paramKey: 'minPlayers' });
if (maxPlayers !== undefined && !Number.isNaN(maxPlayers)) activeFilters.push({ label: `Max: ${maxPlayers}`, paramKey: 'maxPlayers' });

function removeFilterUrl(paramKey: string): string {
  const params = new URLSearchParams(searchParams.toString());
  params.delete(paramKey);
  params.delete('page');
  const qs = params.toString();
  return qs ? `/?${qs}` : '/';
}

function formatNumber(n: number): string {
  return n.toLocaleString('en-US');
}
---

<Base title="Browse Servers">
  <!-- Mobile: top bar with title + filter toggle -->
  <div class="flex items-center justify-between lg:hidden mb-5">
    <div>
      <h1 class="text-xl font-bold tracking-tight">Servers</h1>
      <p class="text-xs font-medium text-txt-3 tabular-nums mt-0.5">
        {formatNumber(listing.total)} found
      </p>
    </div>
    <button
      id="filter-toggle"
      class="inline-flex items-center gap-2 rounded-lg bg-surface-2 px-4 py-2.5 text-sm font-medium text-txt-2 ring-1 ring-edge transition-all hover:bg-surface-3 hover:text-txt"
      aria-label="Toggle filters"
    >
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
      </svg>
      Filters
      {activeFilters.length > 0 && (
        <span class="flex h-5 w-5 items-center justify-center rounded-full bg-accent text-[10px] font-bold text-surface-0">
          {activeFilters.length}
        </span>
      )}
    </button>
  </div>

  <!-- Backdrop for mobile sidebar -->
  <div
    id="sidebar-backdrop"
    class="fixed inset-0 z-[55] bg-black/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"
    aria-hidden="true"
  />

  <!-- Two-column dashboard layout -->
  <div class="flex gap-6 items-start">

    <!-- ═══ Sidebar ═══ -->
    <aside
      id="sidebar"
      class="sidebar-drawer sidebar-scroll fixed inset-y-0 left-0 z-[60] w-[300px] overflow-y-auto bg-surface-1 border-r border-edge p-5 pt-6 -translate-x-full transition-transform duration-300 ease-out lg:static lg:z-auto lg:w-[280px] lg:shrink-0 lg:translate-x-0 lg:border-0 lg:bg-transparent lg:p-0 lg:transition-none"
    >
      <!-- Mobile sidebar header -->
      <div class="flex items-center justify-between mb-5 lg:hidden">
        <span class="text-base font-semibold text-txt">Filters</span>
        <button
          id="filter-close"
          class="flex h-8 w-8 items-center justify-center rounded-lg text-txt-3 transition-colors hover:bg-surface-3 hover:text-txt"
          aria-label="Close filters"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Sticky filter panel on desktop -->
      <div class="lg:sticky lg:top-24 lg:max-h-[calc(100vh-7rem)] lg:overflow-y-auto lg:rounded-xl lg:border lg:border-edge lg:bg-surface-2/30 lg:p-5 sidebar-scroll">
        <SearchFilters
          client:load
          initialQuery={q ?? ''}
          initialSort={sort ?? 'players'}
          initialSortDir={sortDir ?? 'desc'}
          initialGamemode={category ?? ''}
          initialLocale={locale ?? ''}
          initialMinPlayers={minPlayers !== undefined && !Number.isNaN(minPlayers) ? String(minPlayers) : ''}
          initialMaxPlayers={maxPlayers !== undefined && !Number.isNaN(maxPlayers) ? String(maxPlayers) : ''}
          categories={categories}
          locales={localeOptions}
        />

        <!-- Popular tags -->
        {popularTags.length > 0 && (
          <div class="mt-5 pt-5 border-t border-edge/50">
            <h2 class="text-[11px] font-semibold uppercase tracking-widest text-txt-3 mb-3">
              Popular Tags
            </h2>
            <TagCloud tags={popularTags} />
          </div>
        )}
      </div>
    </aside>

    <!-- ═══ Main content ═══ -->
    <div class="flex-1 min-w-0">
      <!-- Desktop header -->
      <div class="hidden lg:flex items-baseline justify-between mb-5">
        <h1 class="text-2xl font-bold tracking-tight">Servers</h1>
        <p class="text-sm font-medium text-txt-3 tabular-nums">
          {formatNumber(listing.total)} found
        </p>
      </div>

      <!-- Active filter chips -->
      {activeFilters.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-5 fade-in">
          {activeFilters.map((filter) => (
            <a
              href={removeFilterUrl(filter.paramKey)}
              class="inline-flex items-center gap-1.5 rounded-lg bg-accent/10 px-3 py-1 text-xs font-semibold text-accent ring-1 ring-accent/20 transition-all hover:bg-accent/20 hover:ring-accent/40"
            >
              {filter.label}
              <span class="text-accent/60">&times;</span>
            </a>
          ))}
          <a
            href="/"
            class="inline-flex items-center rounded-lg bg-surface-2 px-3 py-1 text-xs font-medium text-txt-3 ring-1 ring-edge transition-all hover:text-txt hover:bg-surface-3"
          >
            Clear all
          </a>
        </div>
      )}

      <!-- Server grid or empty state -->
      {listing.servers.length > 0 ? (
        <ServerGrid>
          {listing.servers.map((server) => (
            <ServerCard
              id={server.id}
              name={server.hostnameClean}
              players={server.currentPlayers}
              maxPlayers={server.maxPlayers}
              isOnline={server.isOnline}
              gamemode={server.gametype}
              mapname={server.mapname}
              locale={server.locale}
              iconUrl={getServerIconUrl(server.id, server.iconVersion)}
              lastSeenAt={server.lastSeenAt}
              updatedAt={server.updatedAt}
            />
          ))}
        </ServerGrid>
      ) : (
        <div class="flex flex-col items-center justify-center rounded-xl border border-edge bg-surface-2 py-20 text-center">
          <svg class="h-12 w-12 text-txt-3 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <p class="text-lg font-semibold text-txt-2">No servers found</p>
          <p class="mt-1 text-sm text-txt-3">Try adjusting your search or filters</p>
          {activeFilters.length > 0 && (
            <a
              href="/"
              class="mt-5 rounded-lg bg-accent px-5 py-2 text-sm font-semibold text-surface-0 transition-all hover:bg-accent-hover"
            >
              Clear all filters
            </a>
          )}
        </div>
      )}

      <!-- Pagination -->
      <Pagination
        currentPage={listing.page}
        totalPages={listing.totalPages}
        baseUrl="/"
        searchParams={searchParams}
      />
    </div>
  </div>

  <!-- Sidebar toggle script -->
  <script>
    function initSidebar() {
      const toggle = document.getElementById('filter-toggle');
      const close = document.getElementById('filter-close');
      const sidebar = document.getElementById('sidebar');
      const backdrop = document.getElementById('sidebar-backdrop');

      if (!toggle || !sidebar || !backdrop) return;

      function openSidebar() {
        sidebar!.classList.remove('-translate-x-full');
        backdrop!.classList.remove('opacity-0', 'pointer-events-none');
        document.body.classList.add('sidebar-open');
      }

      function closeSidebar() {
        sidebar!.classList.add('-translate-x-full');
        backdrop!.classList.add('opacity-0', 'pointer-events-none');
        document.body.classList.remove('sidebar-open');
      }

      toggle.addEventListener('click', openSidebar);
      close?.addEventListener('click', closeSidebar);
      backdrop.addEventListener('click', closeSidebar);

      // Close on Escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !sidebar.classList.contains('-translate-x-full')) {
          closeSidebar();
        }
      });
    }

    // Support both initial load and Astro View Transitions
    initSidebar();
    document.addEventListener('astro:page-load', initSidebar);
  </script>
</Base>
