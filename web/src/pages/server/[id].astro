---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import PlayerChart from '../../components/PlayerChart.tsx';
import { db } from '../../lib/db.js';
import { getServerDetail } from '../../lib/queries.js';
import { getServerIconUrl, getConnectUrl } from '../../lib/url-helpers.js';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/');
}

const server = await getServerDetail(db, id);

if (!server) {
  return new Response(null, { status: 404, statusText: 'Server not found' });
}

const connectUrl = getConnectUrl(server.id);
const iconUrl = getServerIconUrl(server.id, server.iconVersion);

/** Format a Date as a human-readable string */
function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  });
}

const playerPercent = server.maxPlayers > 0
  ? Math.round((server.currentPlayers / server.maxPlayers) * 100)
  : 0;

const RESOURCES_INITIAL_LIMIT = 50;
const hasExtraResources = server.resources.length > RESOURCES_INITIAL_LIMIT;
---

<Base title={server.hostnameClean}>
  <!-- Back link -->
  <a href="/" class="mb-4 inline-flex items-center text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">
    &larr; Back to servers
  </a>

  <!-- Header section -->
  <div class="rounded-lg border border-gray-200 bg-white p-6 dark:border-gray-800 dark:bg-gray-900">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:gap-6">
      <!-- Server icon -->
      <img
        src={iconUrl}
        alt={`${server.hostnameClean} icon`}
        width="96"
        height="96"
        class="h-16 w-16 shrink-0 rounded-lg object-cover sm:h-24 sm:w-24"
        loading="eager"
      />

      <div class="min-w-0 flex-1">
        <!-- Server name + status badge -->
        <div class="flex flex-wrap items-center gap-3">
          <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">{server.hostnameClean}</h1>
          {server.isOnline ? (
            <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800 dark:bg-green-900/30 dark:text-green-400">
              Online
            </span>
          ) : (
            <span class="inline-flex items-center rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-medium text-red-800 dark:bg-red-900/30 dark:text-red-400">
              Offline
            </span>
          )}
        </div>

        <!-- Player count with progress bar -->
        <div class="mt-3">
          <div class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
            <span class="font-medium">{server.currentPlayers}/{server.maxPlayers} players</span>
            <span class="text-gray-400 dark:text-gray-600">({playerPercent}%)</span>
          </div>
          <div class="mt-1.5 h-2 w-full max-w-xs overflow-hidden rounded-full bg-gray-200 dark:bg-gray-700">
            <div
              class="h-full rounded-full bg-green-500 transition-all"
              style={`width: ${playerPercent}%`}
            />
          </div>
        </div>

        <!-- Connect button -->
        <div class="mt-4">
          <a
            href={connectUrl}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center rounded-lg bg-green-600 px-5 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900"
          >
            Join Server
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Player History Chart (HIST-01, HIST-02) -->
  <div class="mt-6 rounded-lg border border-gray-200 bg-white p-6 dark:border-gray-800 dark:bg-gray-900">
    <h2 class="text-lg font-semibold mb-4">Player History</h2>
    <PlayerChart serverId={server.id} client:load />
  </div>

  <!-- Info grid section -->
  <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div class="rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-800 dark:bg-gray-900">
      <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Gamemode</dt>
      <dd class="mt-1 text-sm text-gray-900 dark:text-gray-100">{server.gametype ?? 'Not specified'}</dd>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-800 dark:bg-gray-900">
      <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Map</dt>
      <dd class="mt-1 text-sm text-gray-900 dark:text-gray-100">{server.mapname ?? 'Not specified'}</dd>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-800 dark:bg-gray-900">
      <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Locale</dt>
      <dd class="mt-1 text-sm text-gray-900 dark:text-gray-100">{server.locale ?? 'Not specified'}</dd>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-800 dark:bg-gray-900">
      <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Project Name</dt>
      <dd class="mt-1 text-sm text-gray-900 dark:text-gray-100">{server.projectName ?? 'Not specified'}</dd>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-800 dark:bg-gray-900">
      <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Last Updated</dt>
      <dd class="mt-1 text-sm text-gray-900 dark:text-gray-100">{formatDate(server.updatedAt)}</dd>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-800 dark:bg-gray-900">
      <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Last Seen in Stream</dt>
      <dd class="mt-1 text-sm text-gray-900 dark:text-gray-100">{formatDate(server.lastSeenAt)}</dd>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-800 dark:bg-gray-900">
      <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">First Tracked</dt>
      <dd class="mt-1 text-sm text-gray-900 dark:text-gray-100">{formatDate(server.createdAt)}</dd>
    </div>
  </div>

  <!-- Project Description -->
  {server.projectDescription && (
    <div class="mt-6 rounded-lg border border-gray-200 bg-white p-6 dark:border-gray-800 dark:bg-gray-900">
      <h2 class="text-lg font-semibold">About</h2>
      <p class="mt-2 text-sm leading-relaxed text-gray-700 dark:text-gray-300">
        {server.projectDescription}
      </p>
    </div>
  )}

  <!-- Tags section -->
  {server.tags.length > 0 && (
    <div class="mt-6 rounded-lg border border-gray-200 bg-white p-6 dark:border-gray-800 dark:bg-gray-900">
      <h2 class="text-lg font-semibold">Tags</h2>
      <div class="mt-3 flex flex-wrap gap-2">
        {server.tags.map((tag) => (
          <a
            href={`/?tag=${encodeURIComponent(tag)}`}
            class="rounded-full bg-blue-100 px-3 py-1 text-xs font-medium text-blue-700 hover:bg-blue-200 dark:bg-blue-900/30 dark:text-blue-400 dark:hover:bg-blue-900/50"
          >
            {tag}
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Resources section (BROW-09) -->
  {server.resources.length > 0 && (
    <div class="mt-6 rounded-lg border border-gray-200 bg-white p-6 dark:border-gray-800 dark:bg-gray-900">
      <h2 class="text-lg font-semibold">Running Resources ({server.resources.length})</h2>
      {hasExtraResources ? (
        <details class="mt-3">
          <summary class="cursor-pointer text-sm text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300">
            Showing first {RESOURCES_INITIAL_LIMIT} of {server.resources.length} resources. Click to show all.
          </summary>
          <div class="mt-3 flex flex-wrap gap-1.5">
            {server.resources.map((resource) => (
              <span class="rounded bg-gray-100 px-2 py-0.5 font-mono text-xs text-gray-700 dark:bg-gray-800 dark:text-gray-300">
                {resource}
              </span>
            ))}
          </div>
        </details>
        <div class="mt-3 flex flex-wrap gap-1.5">
          {server.resources.slice(0, RESOURCES_INITIAL_LIMIT).map((resource) => (
            <span class="rounded bg-gray-100 px-2 py-0.5 font-mono text-xs text-gray-700 dark:bg-gray-800 dark:text-gray-300">
              {resource}
            </span>
          ))}
        </div>
      ) : (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {server.resources.map((resource) => (
            <span class="rounded bg-gray-100 px-2 py-0.5 font-mono text-xs text-gray-700 dark:bg-gray-800 dark:text-gray-300">
              {resource}
            </span>
          ))}
        </div>
      )}
    </div>
  )}
</Base>
